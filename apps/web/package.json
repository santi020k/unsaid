{
  "name": "@unsaid/web",
  "version": "1.0.0",
  "description": "Unsaid marketing and app frontend (Astro 6, Cloudflare Worker + assets).",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/santi020k/unsaid.git",
    "directory": "apps/web"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "deploy": "wrangler deploy",
    "preview": "astro preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "astro check",
    "test": "playwright test",
    "test:install": "playwright install chromium",
    "lighthouse": "lhci autorun --config=lighthouserc.cjs",
    "lighthouse:mobile": "lhci autorun --config=lighthouserc.mobile.cjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.2.1",
    "@astrojs/sitemap": "^3.3.1",
    "@tailwindcss/vite": "^4.1.5",
    "@unsaid/shared": "workspace:^",
    "astro": "^6.1.9",
    "astro-robots-txt": "^1.0.0",
    "tailwindcss": "^4.1.5"
  },
  "devDependencies": {
    "wrangler": "^4.85.0",
    "@astrojs/check": "^0.9.8",
    "@astrojs/ts-plugin": "^1.10.7",
    "@axe-core/playwright": "^4.11.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.49.0",
    "@santi020k/eslint-config-astro": "^1.5.0",
    "@santi020k/eslint-config-basic": "^1.5.0",
    "typescript": "^6.0.3"
  }
}
