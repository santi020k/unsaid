# Copy this file to .env and fill in your values
# Local dev: use the Turnstile test keys below

# Hono API origin (no trailing slash). May omit https:// for a public hostname; loopback may omit http://.
# Production example: https://api.unsaid.santi020k.com
PUBLIC_API_URL=http://localhost:8787

# Cloudflare Turnstile site key
# Test key (always passes): 1x00000000000000000000AA
# Get real key at: dash.cloudflare.com > Turnstile
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
