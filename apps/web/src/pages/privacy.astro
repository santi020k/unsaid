---
import LegalPageShell from '@/components/molecules/LegalPageShell.astro'

import { useTranslations } from '@/i18n/utils'
import { SITE } from '@/site.config'

const locale = 'en'
const t = useTranslations(locale)
---

<LegalPageShell
  locale={locale}
  title={t('legal.privacy_title')}
  description={t('legal.privacy_desc')}
  lastUpdatedLabel={t('legal.last_updated')}
>
  <section>
    <h2>{t('privacy.summary_title')}</h2>
    <p>{t('privacy.summary_body')}</p>
  </section>
  <section>
    <h2>{t('privacy.content_title')}</h2>
    <p>{t('privacy.content_body')}</p>
  </section>
  <section>
    <h2>{t('privacy.abuse_title')}</h2>
    <p>{t('privacy.abuse_body')}</p>
  </section>
  <section>
    <h2>{t('privacy.no_profile_title')}</h2>
    <p>{t('privacy.no_profile_body')}</p>
  </section>
  <section>
    <h2>{t('privacy.translation_title')}</h2>
    <p>{t('privacy.translation_body')}</p>
  </section>
  <section>
    <h2>{t('privacy.choices_title')}</h2>
    <p>{t('privacy.choices_body')}</p>
  </section>
  <section>
    <h2>{t('privacy.contact_title')}</h2>
    <p>
      {t('privacy.contact_prefix')}{' '}
      <a
        href={SITE.repositoryUrl}
        target="_blank"
        rel="noopener noreferrer"
      >{t('privacy.contact_github')}
      </a>{t('privacy.contact_middle')}{' '}
      <a
        href={SITE.authorUrl}
        target="_blank"
        rel="noopener noreferrer"
      >{t('privacy.contact_author')}
      </a> {t('privacy.contact_suffix')}
    </p>
  </section>
  <section>
    <h2>{t('privacy.changes_title')}</h2>
    <p>{t('privacy.changes_body')}</p>
  </section>
</LegalPageShell>
