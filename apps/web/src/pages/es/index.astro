---
import PostForm from '@/components/molecules/PostForm.astro'
import TruthFeed from '@/components/organisms/TruthFeed.astro'

import { useTranslations } from '@/i18n/utils'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { SITE } from '@/site.config'
import { FEED_PAGE_SIZE, type Post } from '@unsaid/shared'

const locale = 'es'
const t = useTranslations(locale)
let initialPosts: Post[] = []
let initialHasMore = false

try {
  const res = await fetch(
    `${SITE.apiUrl}/api/posts?locale=${locale}&page=1&limit=${String(FEED_PAGE_SIZE)}`
  )

  if (res.ok) {
    const json = (await res.json()) as { data: { posts: Post[], total: number } }

    initialPosts = json.data.posts

    initialHasMore = json.data.total > json.data.posts.length
  }
} catch {
  // Feed is empty; client-side publish still works
}
---

<BaseLayout locale={locale}>
  <section class="section-shell pt-24 pb-16 text-center">
    <p class="
      mb-6 animate-fade-in text-label
      motion-reduce:animate-none
    "
    >
      {t('hero.eyebrow')}
    </p>
    <h1
      class="
        mb-6 animate-slide-up heading-display text-5xl leading-none
        whitespace-pre-line
        motion-reduce:animate-none
        sm:text-6xl
      "
      style="animation-delay: 40ms"
    >
      {t('hero.headline')}
    </h1>
    <p
      class="
        animate-slide-up text-lg text-text-muted
        motion-reduce:animate-none
      "
      style="animation-delay: 120ms"
    >
      {t('hero.sub')}
    </p>
  </section>

  <div class="section-shell pt-0">
    <PostForm locale={locale} />
  </div>

  <div class="section-shell pt-8">
    <TruthFeed
      initialHasMore={initialHasMore}
      initialPosts={initialPosts}
      locale={locale}
    />
  </div>
</BaseLayout>
