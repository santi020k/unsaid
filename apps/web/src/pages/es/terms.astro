---
import LegalPageShell from '@/components/molecules/LegalPageShell.astro'

import { useTranslations } from '@/i18n/utils'
import { SITE } from '@/site.config'

const locale = 'es'
const t = useTranslations(locale)
const licenseOnGit = `${SITE.repositoryUrl}/blob/main/LICENSE`
---

<LegalPageShell
  locale={locale}
  title={t('legal.terms_title')}
  description={t('legal.terms_desc')}
  lastUpdatedLabel={t('legal.last_updated')}
>
  <section>
    <h2>{t('terms.acceptance_title')}</h2>
    <p>{t('terms.acceptance_body')}</p>
  </section>
  <section>
    <h2>{t('terms.service_title')}</h2>
    <p>{t('terms.service_body')}</p>
  </section>
  <section>
    <h2>{t('terms.content_title')}</h2>
    <p>{t('terms.content_body')}</p>
  </section>
  <section>
    <h2>{t('terms.disclaimer_title')}</h2>
    <p>
      {t('terms.disclaimer_prefix')}{' '}
      <a
        href={licenseOnGit}
        target="_blank"
        rel="noopener noreferrer"
      >{t('terms.disclaimer_project')}
      </a>{' '}
      {t('terms.disclaimer_suffix')}
    </p>
  </section>
  <section>
    <h2>{t('terms.liability_title')}</h2>
    <p>{t('terms.liability_body')}</p>
  </section>
  <section>
    <h2>{t('terms.indemnity_title')}</h2>
    <p>{t('terms.indemnity_body')}</p>
  </section>
  <section>
    <h2>{t('terms.license_title')}</h2>
    <p>
      {t('terms.license_prefix')}{' '}
      <a
        href={licenseOnGit}
        target="_blank"
        rel="noopener noreferrer"
      >{t('terms.license_link')}
      </a>{t('terms.license_suffix')}
    </p>
  </section>
  <section>
    <h2>{t('terms.changes_title')}</h2>
    <p>{t('terms.changes_body')}</p>
  </section>
  <section>
    <h2>{t('terms.contact_title')}</h2>
    <p>
      {t('terms.contact_prefix')}{' '}
      <a
        href={SITE.repositoryUrl}
        target="_blank"
        rel="noopener noreferrer"
      >{t('terms.contact_github')}
      </a>{t('terms.contact_suffix')}
    </p>
  </section>
</LegalPageShell>
