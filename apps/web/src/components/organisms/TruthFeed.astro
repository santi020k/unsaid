---
import TruthCard from '@/components/atoms/TruthCard.astro'

import { useTranslations } from '@/i18n/utils'
import type { SupportedLocale } from '@/site.config'
import { SITE } from '@/site.config'
import type { Post } from '@unsaid/shared'

interface Props {
  initialPosts: Post[]
  locale: SupportedLocale
}

const { initialPosts, locale } = Astro.props
const t = useTranslations(locale)
---

<section aria-label={t('feed.title')}>
  <div class="mb-8 flex items-center gap-3">
    <span class="accent-dot"></span>
    <h2 class="text-label">{t('feed.title')}</h2>
  </div>

  <div
    id="truth-feed"
    class="flex flex-col gap-4"
    data-stagger
    data-locale={locale}
    data-api={SITE.apiUrl}
  >
    {
      initialPosts.length === 0 ?
        <p class="py-8 text-center text-sm text-text-muted">{t('feed.empty')}</p> :
        initialPosts.map(post => <TruthCard locale={locale} post={post} />)
    }
  </div>

  {
    initialPosts.length >= 20 && (
      <div class="mt-8 flex justify-center">
        <button id="load-more" class="btn-ghost text-sm">
          {t('feed.load_more')}
        </button>
      </div>
    )
  }
</section>

<script
  is:inline
  define:vars={{
    locale,
    badgeOriginalLabel: t('feed.badge_original'),
    badgeTranslatedLabel: t('feed.badge_translated'),
    badgeOriginalTitle: t('feed.badge_original_aria'),
    badgeTranslatedTitle: t('feed.badge_translated_aria')
  }}
>
  let page = 1
  const feed = document.getElementById('truth-feed')
  const loadMoreBtn = document.getElementById('load-more')
  const apiUrl = feed?.dataset.api?.trim() ?? ''
  const dateLocale = locale === 'es' ? 'es' : 'en'

  const svgDoc =
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-3.5 shrink-0 text-text-muted" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9z"></path></svg>'
  const svgArrows =
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-3.5 shrink-0 text-accent" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"></path></svg>'

  function formatTruthDate(iso) {
    return new Date(iso).toLocaleDateString(dateLocale, {
      day: 'numeric',
      month: 'short',
      year: 'numeric'
    })
  }

  function buildTruthArticle(post, options) {
    const isTranslated = Boolean(post.translation_of)
    const article = document.createElement('article')
    article.className = options?.pulse ?
      'truth-card-interactive animate-accent-pulse' :
      'truth-card-interactive'
    if (!options?.pulse) article.dataset.animate = ''

    const meta = document.createElement('div')
    meta.className = 'mb-3'
    const badge = document.createElement('span')
    badge.className = isTranslated ? 'truth-post-badge border-accent/25' : 'truth-post-badge'
    badge.title = isTranslated ? badgeTranslatedTitle : badgeOriginalTitle
    const tpl = document.createElement('template')
    tpl.innerHTML = isTranslated ? svgArrows : svgDoc
    badge.appendChild(tpl.content.cloneNode(true))
    badge.appendChild(
      document.createTextNode(isTranslated ? badgeTranslatedLabel : badgeOriginalLabel)
    )
    meta.appendChild(badge)
    article.appendChild(meta)

    const p = document.createElement('p')
    p.className = 'font-mono text-sm leading-relaxed text-text-primary'
    p.textContent = post.content
    article.appendChild(p)

    const footer = document.createElement('footer')
    footer.className = 'mt-4 flex items-center gap-3'
    const dot = document.createElement('span')
    dot.className = 'accent-dot'
    const timeEl = document.createElement('time')
    timeEl.className = 'text-xs text-text-faint'
    timeEl.dateTime = post.created_at
    timeEl.textContent = formatTruthDate(post.created_at)
    footer.appendChild(dot)
    footer.appendChild(timeEl)
    article.appendChild(footer)
    return article
  }

  /** Posts array, or null if the request failed (network / offline). */
  async function fetchPosts(p) {
    if (!apiUrl) return null
    try {
      const res = await fetch(`${apiUrl}/api/posts?locale=${locale}&page=${p}`)
      if (!res.ok) return []
      const json = await res.json()
      return json.data?.posts ?? []
    } catch {
      return null
    }
  }

  loadMoreBtn?.addEventListener('click', async () => {
    page++
    loadMoreBtn.setAttribute('disabled', '')
    const posts = await fetchPosts(page)
    if (posts === null) {
      loadMoreBtn.removeAttribute('disabled')
      return
    }
    if (posts.length === 0) { loadMoreBtn.remove(); return }

    for (const post of posts) {
      const article = buildTruthArticle(post, {})
      feed?.appendChild(article)
      requestAnimationFrame(() => article.classList.add('is-visible'))
    }

    loadMoreBtn.removeAttribute('disabled')
    if (posts.length < 20) loadMoreBtn.remove()
  })

  window.addEventListener('truth:published', async () => {
    const fresh = await fetchPosts(1)
    if (fresh === null || !feed) return
    const latest = fresh[0]
    if (!latest) return

    const article = buildTruthArticle(latest, { pulse: true })
    feed.insertBefore(article, feed.firstChild)
  })
</script>
