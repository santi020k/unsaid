---
import Button from '@/components/atoms/Button.astro'

import { useTranslations } from '@/i18n/utils'
import type { SupportedLocale } from '@/site.config'
import { SITE } from '@/site.config'
import { POST_MAX_LENGTH, POST_MIN_LENGTH } from '@unsaid/shared'

interface Props {
  locale: SupportedLocale
}

const { locale } = Astro.props
const t = useTranslations(locale)
---

<section class="truth-card" aria-label={t('form.title')}>
  <h2 class="mb-6 heading-display text-2xl">{t('form.title')}</h2>

  <form id="post-form" novalidate>
    <input type="hidden" name="locale" value={locale} />

    <div class="relative">
      <textarea
        id="post-content"
        name="content"
        rows={4}
        maxlength={POST_MAX_LENGTH}
        minlength={POST_MIN_LENGTH}
        placeholder={t('form.placeholder')}
        class="field-surface"
        aria-describedby="char-count form-status"
        required
      >
      </textarea>
      <span
        id="char-count"
        aria-live="polite"
        class="absolute right-3 bottom-3 text-xs text-text-faint tabular-nums"
      >
        {POST_MAX_LENGTH}
      </span>
    </div>

    <div class="mt-5 flex flex-col gap-4">
      <p
        id="form-status"
        role="status"
        aria-live="polite"
        class="hidden text-sm text-text-muted"
      >
      </p>

      <!-- Turnstile left, submit right on sm+; stacked on narrow screens so ~300px widget + label fit. -->
      <div
        class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between sm:gap-6"
      >
        <div
          class="turnstile-host flex shrink-0 justify-center sm:justify-start [&_.cf-turnstile]:inline-block [&_.cf-turnstile_iframe]:max-w-full [&_.cf-turnstile_iframe]:rounded-card [&_.cf-turnstile_iframe]:border [&_.cf-turnstile_iframe]:border-border/50 [&_.cf-turnstile_iframe]:shadow-none"
        >
          <div
            class="cf-turnstile"
            data-sitekey={SITE.turnstileSiteKey}
            data-theme="dark"
            data-size="normal"
          >
          </div>
        </div>
        <Button type="submit" class="w-full shrink-0 sm:w-auto sm:self-center" id="submit-btn">
          {t('form.submit')}
        </Button>
      </div>
    </div>
  </form>
</section>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>

<script is:inline define:vars={{ locale, maxLen: POST_MAX_LENGTH, minLen: POST_MIN_LENGTH, apiUrl: SITE.apiUrl }}>
  const form = document.getElementById('post-form')
  const textarea = document.getElementById('post-content')
  /** Astro/ESLint-friendly multiline textarea leaves whitespace-only body; strip so caret starts at line 1. */
  if (textarea) textarea.value = textarea.value.trimStart()
  const charCount = document.getElementById('char-count')
  const statusEl = document.getElementById('form-status')
  const submitBtn = document.getElementById('submit-btn')

  textarea?.addEventListener('input', () => {
    const remaining = maxLen - textarea.value.length
    if (charCount) charCount.textContent = String(remaining)
  })

  function showStatus(msg, isError = false) {
    if (!statusEl) return
    statusEl.textContent = msg
    statusEl.classList.remove('hidden', 'text-text-muted', 'text-danger', 'text-success')
    statusEl.classList.add(isError ? 'text-danger' : 'text-success')
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()

    const content = textarea?.value.trim() ?? ''
    if (content.length < minLen) { showStatus('Too short.', true); return }
    if (content.length > maxLen) { showStatus('Too long.', true); return }

    const token = document.querySelector('[name="cf-turnstile-response"]')?.value
    if (!token) { showStatus('Please complete the CAPTCHA.', true); return }

    submitBtn?.setAttribute('disabled', '')
    submitBtn.textContent = 'Publishing…'

    try {
      const res = await fetch(`${apiUrl}/api/posts`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content, locale, captchaToken: token }),
      })

      if (res.status === 429) { showStatus('Daily limit reached. Come back tomorrow.', true); return }
      if (!res.ok) { showStatus('Something went wrong.', true); return }

      showStatus('Truth published.')
      form.reset()
      if (textarea) textarea.value = textarea.value.trimStart()
      if (charCount) charCount.textContent = String(maxLen)
      window.turnstile?.reset()
      window.dispatchEvent(new CustomEvent('truth:published'))
    } catch {
      showStatus('Something went wrong.', true)
    } finally {
      submitBtn?.removeAttribute('disabled')
      submitBtn.textContent = 'Publish anonymously'
    }
  })
</script>
