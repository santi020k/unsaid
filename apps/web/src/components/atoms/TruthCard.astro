---
import { useTranslations } from '@/i18n/utils'
import type { SupportedLocale } from '@/site.config'
import type { Post } from '@unsaid/shared'

interface Props {
  post: Post
  locale: SupportedLocale
}

const { post, locale } = Astro.props
const t = useTranslations(locale)
const isTranslation = post.translation_of != null && post.translation_of !== ''

const date = new Date(post.created_at).toLocaleDateString(locale === 'es' ? 'es' : 'en', {
  day: 'numeric',
  month: 'short',
  year: 'numeric'
})
---

<article class="truth-card-interactive" data-animate>
  <div class="mb-3">
    {
      isTranslation ?
        (
          <span
            class="truth-post-badge border-accent/25"
            title={t('feed.badge_translated_aria')}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              class="size-3.5 shrink-0 text-accent"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"
              >
              </path>
            </svg>
            {t('feed.badge_translated')}
          </span>
        ) :
        (
          <span
            class="truth-post-badge"
            title={t('feed.badge_original_aria')}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              class="size-3.5 shrink-0 text-text-muted"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9z"
              >
              </path>
            </svg>
            {t('feed.badge_original')}
          </span>
        )
    }
  </div>
  <p class="font-mono text-sm/relaxed text-text-primary">{post.content}</p>
  <footer class="mt-4 flex items-center gap-3">
    <span class="accent-dot"></span>
    <time class="text-xs text-text-faint" datetime={post.created_at}>{date}</time>
  </footer>
</article>
