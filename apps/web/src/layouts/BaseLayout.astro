---
import TablerIcon from '@/components/atoms/TablerIcon.astro'

import '@/styles/global.css'

import { getAlternatePath, getLocalePaths, useTranslations } from '@/i18n/utils'
import type { SupportedLocale } from '@/site.config'
import { SITE } from '@/site.config'

interface Props {
  title?: string
  description?: string
  locale: SupportedLocale
}

const { title, description = SITE.description, locale } = Astro.props
const pageTitle = title ? `${title} — ${SITE.name}` : SITE.name
const t = useTranslations(locale)
const altPath = getAlternatePath(locale, Astro.url.pathname)
const site = Astro.site ?? new URL(SITE.url)
const canonicalURL = new URL(Astro.url.pathname, site).href
const { en: enPath, es: esPath } = getLocalePaths(Astro.url.pathname)
const enUrl = new URL(enPath, site).href
const esUrl = new URL(esPath, site).href
const homePath = locale === 'en' ? '/' : '/es/'
const ogImageUrl = new URL('/banner.png', site).href
const ogLocale = locale === 'es' ? 'es_ES' : 'en_US'
const ogLocaleAlternate = locale === 'es' ? 'en_US' : 'es_ES'

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: enUrl,
  description: SITE.description,
  inLanguage: ['en', 'es']
}

const legalPath = (slug: string) => (locale === 'en' ? `/${slug}` : `/es/${slug}`)

/** In-app routes shown in the legal row; middots render between items. */
const footerLegalLinks = [
  { href: legalPath('privacy'), label: t('footer.legal_privacy') },
  { href: legalPath('terms'), label: t('footer.legal_terms') }
] as const
---

<!doctype html>
<html lang={locale} class="bg-void">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <!-- Geist via npm or CDN — using Vercel CDN fallback -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/fonts/geist-sans/style.css" />
    <title>{pageTitle}</title>

    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)}></script>

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon-transparent.png" type="image/png" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta
      property="og:image:alt"
      content="Unsaid — The things everyone knows. The things nobody says."
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">{t('nav.skip_to_content')}</a>

    <header class="
      sticky top-0 z-40 animate-header-enter border-b border-border bg-void/90
      backdrop-blur-sm
      motion-reduce:animate-none
    "
    >
      <nav
        aria-label={t('nav.main')}
        class="mx-auto flex max-w-2xl items-center justify-between p-4"
      >
        <a
          href={homePath}
          class="
            flex items-center transition-opacity duration-150
            hover:opacity-80
          "
          aria-label={SITE.name}
        >
          <img
            src="/logo-simple-cropped-transparent.webp"
            alt={SITE.name}
            class="h-8 w-auto object-contain"
          />
        </a>
        <div class="flex items-center gap-4">
          <a
            href={altPath}
            class="
              text-sm text-text-muted transition-colors duration-150
              hover:text-text-primary
            "
          >
            {t('nav.lang')}
          </a>
        </div>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="mt-24 border-t border-border bg-surface/35">
      <div
        class="
          mx-auto max-w-2xl px-4 py-12
          sm:py-14
        "
        data-animate
      >
        <div class="flex min-w-0 flex-col gap-4">
          <div class="space-y-1.5">
            <p class="text-sm/relaxed text-text-muted">
              {t('footer.built_prefix')}
              <a
                href={SITE.authorUrl}
                class="footer-link-legal ml-1 font-medium"
                target="_blank"
                rel="noopener noreferrer"
              >
                {t('footer.author')}
              </a>
            </p>
            <p class="max-w-md text-xs/relaxed text-text-faint">
              {t('footer.privacy')}
            </p>
          </div>

          <div
            class="
              flex flex-col gap-4 border-t border-border/80 pt-4
              sm:flex-row sm:items-center sm:justify-between sm:gap-6
              sm:border-t-0 sm:pt-0
            "
          >
            <nav aria-label={t('footer.legal_nav_aria')}>
              <ul
                class="
                  m-0 flex list-none flex-wrap items-center gap-y-2 p-0 text-xs
                  font-medium
                "
              >
                {footerLegalLinks.map(item => (
                  <li
                    class="
                      inline-flex items-center
                      not-first:before:mx-2.5 not-first:before:inline-block
                      not-first:before:text-text-faint
                      not-first:before:content-['·']
                    "
                  >
                    <a href={item.href} class="footer-link-legal">
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>

            <a
              href={SITE.repositoryUrl}
              class="footer-link-github w-fit"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={t('footer.repo_aria')}
            >
              <TablerIcon class="size-4.5 shrink-0 text-current" name="brand-github" />
              <span>{t('footer.repo')}</span>
            </a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // Scroll-triggered reveal
      const observer = new IntersectionObserver(
        entries => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible')

              observer.unobserve(entry.target)
            }
          }
        }, { threshold: 0.1 }
      )

      document.querySelectorAll('[data-animate], [data-stagger]').forEach(el => observer.observe(el))
    </script>
  </body>
</html>
