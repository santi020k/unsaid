# Copy this file to .dev.vars — Wrangler uses this for local secrets
# Never commit .dev.vars

# Cloudflare Turnstile secret key
# Test key (always passes): 1x0000000000000000000000000000000AA
# Get real key at: dash.cloudflare.com > Turnstile
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Allowed CORS origin (frontend URL)
ALLOWED_ORIGIN=http://localhost:4321

# Comma-separated hostnames accepted from Turnstile verification.
# Keep empty for local test keys; set production hostnames before deploy.
TURNSTILE_ALLOWED_HOSTNAMES=

# Opt in to sending public post text to the configured machine translation provider.
ENABLE_AUTO_TRANSLATION=false

# Unset or "false" to enforce the daily per-IP post cap (3) in local dev
DISABLE_POST_RATE_LIMIT=true
