{
  "name": "@unsaid/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "db:migrate": "wrangler d1 migrations apply unsaid-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply unsaid-db --remote",
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "pnpm run db:migrate:remote && pnpm run deploy:worker",
    "deploy:worker": "wrangler deploy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "@unsaid/shared": "workspace:^",
    "hono": "^4.12.15",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250430.0",
    "@santi020k/eslint-config-basic": "^1.5.0",
    "@santi020k/eslint-config-hono": "^1.5.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.85.0"
  }
}
