{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".astro/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["**/*.{ts,tsx,js,astro}"]
    },
    "check": {
      "dependsOn": ["^build"],
      "inputs": ["**/*.{ts,tsx,js,astro,json}"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "deploy": {
      "dependsOn": ["build"]
    }
  }
}
