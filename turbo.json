{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".astro/**"],
      "env": ["PUBLIC_API_URL", "PUBLIC_TURNSTILE_SITE_KEY"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["**/*.{ts,tsx,js,astro}"]
    },
    "check": {
      "dependsOn": ["^build"],
      "inputs": ["**/*.{ts,tsx,js,astro,json}"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false,
      "passThroughEnv": ["CLOUDFLARE_API_TOKEN", "CLOUDFLARE_ACCOUNT_ID"]
    }
  }
}
