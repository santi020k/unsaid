{
  "name": "unsaid",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter @unsaid/api db:migrate && turbo run dev",
    "lint": "turbo run lint",
    "check": "turbo run check",
    "test": "turbo run test",
    "spellcheck": "cspell '**/*.{md,json}' --no-progress --exclude '**/node_modules/**' --exclude '**/dist/**'",
    "knip": "knip",
    "pre-commit": "lint-staged --quiet",
    "pre-push": "pnpm run spellcheck && turbo run lint check",
    "prepare": "husky"
  },
  "devDependencies": {
    "cspell": "^8.17.3",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "knip": "^5.44.0",
    "lint-staged": "^15.5.1",
    "turbo": "^2.5.4",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "apps/web/**/*.{js,ts,astro}": [
      "eslint --fix"
    ],
    "apps/api/**/*.{js,ts}": [
      "eslint --fix"
    ],
    "**/*.{md,json}": [
      "cspell --no-progress"
    ]
  },
  "pnpm": {
    "overrides": {
      "yaml": "^2.8.3"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd",
      "unrs-resolver"
    ]
  }
}
